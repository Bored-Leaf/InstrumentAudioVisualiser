#include "CircularBuffer"

// ========== Public ==========

template <typename T>
CircularBuffer<T>::CircularBuffer(const int size) 
                            : m_capacity{size}
                            , m_buffer(size) {}

template <typename T>
bool CircularBuffer<T>::write(const std::vector<T>& chunk) {
    if (chunk.size() > m_capacity - m_size) return false;

    for (size_t i = 0;i < chunk.size();i++) {
        m_buffer[(m_writeIndex + i) % m_capacity] = chunk[i];
    }

    m_writeIndex += chunk.size();
    m_writeIndex %= m_capacity;
    m_size += chunk.size();

    return true;
}